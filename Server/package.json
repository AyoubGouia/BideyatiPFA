{
  "name": "bideyatipfa",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "nodemon --exec ts-node --files src/server.ts",
    "test:db:up": "docker compose -f docker-compose.test.yml up -d",
    "test:db:down": "docker compose -f docker-compose.test.yml down -v",
    "test:db:migrate": "cross-env DOTENV_CONFIG_PATH=.env.test npx prisma migrate deploy",
    "test:db:seed": "cross-env DOTENV_CONFIG_PATH=.env.test ts-node prisma/seed/seedTest.ts",
    "test:db:migrate:current": "cross-env DOTENV_CONFIG_PATH=.env npx prisma migrate deploy",
    "test:db:seed:current": "cross-env DOTENV_CONFIG_PATH=.env ts-node prisma/seed/seedTest.ts",
    "seed:academic-reference": "cross-env DOTENV_CONFIG_PATH=.env ts-node prisma/seedAcademicReference.ts",
    "seed:academic-reference:with-formulas": "cross-env DOTENV_CONFIG_PATH=.env ALLOW_SPECIALITE_FORMULA_WRITES=true ts-node prisma/seedAcademicReference.ts",
    "test:integration": "cross-env DOTENV_CONFIG_PATH=.env.test jest --config jest.config.ts --runInBand",
    "test:integration:current": "cross-env DOTENV_CONFIG_PATH=.env jest --config jest.config.ts --runInBand",
    "test:prepare": "npm run test:db:up && npm run test:db:migrate && npm run test:db:seed",
    "test:prepare:current": "npm run test:db:migrate:current && npm run test:db:seed:current",
    "test:all": "npm run test:prepare && npm run test:integration"
  },
  "dependencies": {
    "@google/genai": "^1.50.1",
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "axios": "^1.14.0",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.1",
    "pdf-parse": "^1.1.1",
    "pg": "^8.20.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/node": "^20.12.12",
    "@types/supertest": "^7.2.0",
    "cross-env": "^10.1.0",
    "jest": "^30.3.0",
    "nodemon": "^3.1.2",
    "prisma": "^7.5.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  }
}
