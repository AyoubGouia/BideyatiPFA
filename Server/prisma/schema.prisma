generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id              String           @id @default(uuid())
  nom             String
  prenom          String
  email           String           @unique
  telephone       String?
  motDePasseHash  String
  actif           Boolean          @default(true)
  dateCreation    DateTime         @default(now())
  role            Role             @default(VISITOR)
  sectionId       String?
  dateNaissance   DateTime?
  adminProfile    AdminProfile?
  favoris         Favori[]
  notes           NoteEtudiant[]
  questionnaire   Questionnaire?
  recommandations Recommandation[]
  sessions        Session[]
  studentProfile  StudentProfile?
  section         Section?         @relation(fields: [sectionId], references: [id])
}

model StudentProfile {
  id         String  @id @default(uuid())
  numeroBac  String  @unique
  moyenneBac Float?
  userId     String  @unique
  region     String?
  score      Float?
  user       User    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AdminProfile {
  id          String @id @default(uuid())
  niveauAcces Int    @default(1)
  userId      String @unique
  user        User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Session {
  id             String   @id @default(uuid())
  token          String   @unique
  dateExpiration DateTime
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Section {
  id                     String                 @id @default(uuid())
  nom                    String                 @unique
  capacitesAdmissions    CapaciteAdmission[]
  matieres               SectionMatiere[]
  statistiquesAdmissions StatistiqueAdmission[]
  users                  User[]
}

model Matiere {
  id       String           @id @default(uuid())
  nom      String
  notes    NoteEtudiant[]
  sections SectionMatiere[]
}

model SectionMatiere {
  sectionId   String
  matiereId   String
  coefficient Float
  matiere     Matiere @relation(fields: [matiereId], references: [id], onDelete: Cascade)
  section     Section @relation(fields: [sectionId], references: [id], onDelete: Cascade)

  @@id([sectionId, matiereId])
}

model NoteEtudiant {
  id        String  @id @default(uuid())
  valeur    Float
  annee     Int
  userId    String
  matiereId String
  matiere   Matiere @relation(fields: [matiereId], references: [id], onDelete: Cascade)
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Universite {
  id             String          @id
  nom            String
  ville          String
  region         String
  description    String?
  adresse        String?
  code           Int?            @unique
  nomAr          String?
  siteweb        String?
  etablissements Etablissement[]
  specialites    Specialite[]
}

model Etablissement {
  id           String       @id
  code         Int          @unique
  nom          String
  nomAr        String?
  website      String?
  gouvernorat  String?
  type         String?
  lat          Float?
  lon          Float?
  universiteId String
  universite   Universite   @relation(fields: [universiteId], references: [id], onDelete: Cascade)
  favoris      Favori[]
  specialites  Specialite[]
}

model Specialite {
  id                     String                 @id @default(uuid())
  nom                    String
  domaine                String?
  scoreMinimum           Float?
  universiteId           String?
  codeOrientation        String                 @unique
  etablissementId        String?
  formuleBrute           String?
  capacitesAdmissions    CapaciteAdmission[]
  favoris                Favori[]
  metiers                MetierSpecialite[]
  recommandations        Recommandation[]
  etablissement          Etablissement?         @relation(fields: [etablissementId], references: [id])
  universite             Universite?            @relation(fields: [universiteId], references: [id])
  statistiquesAdmissions StatistiqueAdmission[]
}

model StatistiqueAdmission {
  id                String     @id @default(uuid())
  annee             Int
  scoreMinimum      Float?
  tauxAdmission     Float?
  specialiteId      String
  scoreDernierAdmis Float
  sectionId         String?
  section           Section?   @relation(fields: [sectionId], references: [id])
  specialite        Specialite @relation(fields: [specialiteId], references: [id], onDelete: Cascade)

  @@unique([annee, sectionId, specialiteId])
}

model CapaciteAdmission {
  id           String     @id @default(uuid())
  annee        Int
  tour         String
  sectionId    String?
  capacite     Int
  specialiteId String
  section      Section?   @relation(fields: [sectionId], references: [id])
  specialite   Specialite @relation(fields: [specialiteId], references: [id], onDelete: Cascade)

  @@unique([annee, tour, sectionId, specialiteId])
}

model Metier {
  id          String             @id
  titre       String
  secteur     String
  tags        String[]
  specialites MetierSpecialite[]
}

model MetierSpecialite {
  metierId     String
  specialiteId String
  metier       Metier     @relation(fields: [metierId], references: [id], onDelete: Cascade)
  specialite   Specialite @relation(fields: [specialiteId], references: [id], onDelete: Cascade)

  @@id([metierId, specialiteId])
}

model Favori {
  id              String         @id @default(uuid())
  dateAjout       DateTime       @default(now())
  userId          String
  specialiteId    String?
  etablissementId String?
  etablissement   Etablissement? @relation(fields: [etablissementId], references: [id], onDelete: Cascade)
  specialite      Specialite?    @relation(fields: [specialiteId], references: [id], onDelete: Cascade)
  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, specialiteId])
  @@unique([userId, etablissementId])
}

model Questionnaire {
  id               String                 @id @default(uuid())
  dateSoumission   DateTime               @default(now())
  userId           String                 @unique
  profilAcademique ProfilAcademique?
  user             User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  reponses         ReponseQuestionnaire[]
}

model ReponseQuestionnaire {
  id              String        @id @default(uuid())
  question        String
  reponse         String
  questionnaireId String
  questionnaire   Questionnaire @relation(fields: [questionnaireId], references: [id], onDelete: Cascade)
}

model ProfilAcademique {
  id              String        @id @default(uuid())
  moyenneBac      Float
  scorePondere    Float
  questionnaireId String        @unique
  questionnaire   Questionnaire @relation(fields: [questionnaireId], references: [id], onDelete: Cascade)
}

model Recommandation {
  id                 String     @id @default(uuid())
  scoreCompatibilite Float
  rang               Int
  userId             String
  specialiteId       String
  specialite         Specialite @relation(fields: [specialiteId], references: [id], onDelete: Cascade)
  user               User       @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ParametresRecommandation {
  id            String @id @default(uuid())
  poidsScore    Float
  poidsInterets Float
  poidsMatieres Float
}

model JournalAudit {
  id         String   @id @default(uuid())
  action     String
  dateAction DateTime @default(now())
}

model SystemLog {
  id        String   @id @default(uuid())
  level     String
  message   String
  meta      Json?
  timestamp DateTime @default(now())
}

enum Role {
  STUDENT
  ADMIN
  VISITOR
}
