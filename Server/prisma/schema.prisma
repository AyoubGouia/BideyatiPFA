generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  STUDENT
  ADMIN
  VISITOR
}

model User {
  id              String   @id @default(uuid())
  nom             String
  prenom          String
  email           String   @unique
  telephone       String?
  motDePasseHash  String
  actif           Boolean  @default(true)
  dateCreation    DateTime @default(now())
  role            Role     @default(VISITOR)

  // Relations
  studentProfile  StudentProfile?
  adminProfile    AdminProfile?
  sessions        Session[]
  section         Section?           @relation(fields: [sectionId], references: [id])
  sectionId       String?
  notes           NoteEtudiant[]
  favoris         Favori[]
  questionnaire   Questionnaire?
  recommandations Recommandation[]
}

model StudentProfile {
  id         String @id @default(uuid())
  numeroBac  String @unique
  moyenneBac Float?
  userId     String @unique
  user       User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AdminProfile {
  id          String @id @default(uuid())
  niveauAcces Int    @default(1)
  userId      String @unique
  user        User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Session {
  id             String   @id @default(uuid())
  token          String   @unique
  dateExpiration DateTime
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Section {
  id       String           @id @default(uuid())
  nom      String
  matieres SectionMatiere[]
  users    User[]
}

model Matiere {
  id       String           @id @default(uuid())
  nom      String
  sections SectionMatiere[]
  notes    NoteEtudiant[]
}

model SectionMatiere {
  sectionId   String
  matiereId   String
  coefficient Float
  section     Section @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  matiere     Matiere @relation(fields: [matiereId], references: [id], onDelete: Cascade)

  @@id([sectionId, matiereId])
}

model NoteEtudiant {
  id        String  @id @default(uuid())
  valeur    Float
  annee     Int
  userId    String
  matiereId String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  matiere   Matiere @relation(fields: [matiereId], references: [id], onDelete: Cascade)
}

model Universite {
  id          String       @id @default(uuid())
  nom         String
  ville       String
  region      String
  description String?
  specialites Specialite[]
}

model Specialite {
  id                     String                   @id @default(uuid())
  nom                    String
  domaine                String
  scoreMinimum           Float
  universiteId           String
  universite             Universite               @relation(fields: [universiteId], references: [id], onDelete: Cascade)
  statistiquesAdmissions StatistiqueAdmission[]
  metiers                MetierSpecialite[]
  favoris                Favori[]
  recommandations        Recommandation[]
}

model StatistiqueAdmission {
  id            String     @id @default(uuid())
  annee         Int
  scoreMinimum  Float
  tauxAdmission Float
  specialiteId  String
  specialite    Specialite @relation(fields: [specialiteId], references: [id], onDelete: Cascade)
}

model Metier {
  id          String             @id @default(uuid())
  titre       String
  secteur     String
  specialites MetierSpecialite[]
}

model MetierSpecialite {
  metierId     String
  specialiteId String
  metier       Metier     @relation(fields: [metierId], references: [id], onDelete: Cascade)
  specialite   Specialite @relation(fields: [specialiteId], references: [id], onDelete: Cascade)

  @@id([metierId, specialiteId])
}

model Favori {
  id           String     @id @default(uuid())
  dateAjout    DateTime   @default(now())
  userId       String
  specialiteId String
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  specialite   Specialite @relation(fields: [specialiteId], references: [id], onDelete: Cascade)

  @@unique([userId, specialiteId])
}

model Questionnaire {
  id               String                 @id @default(uuid())
  dateSoumission   DateTime               @default(now())
  userId           String                 @unique
  user             User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  reponses         ReponseQuestionnaire[]
  profilAcademique ProfilAcademique?
}

model ReponseQuestionnaire {
  id              String        @id @default(uuid())
  question        String
  reponse         String
  questionnaireId String
  questionnaire   Questionnaire @relation(fields: [questionnaireId], references: [id], onDelete: Cascade)
}

model ProfilAcademique {
  id              String        @id @default(uuid())
  moyenneBac      Float
  scorePondere    Float
  questionnaireId String        @unique
  questionnaire   Questionnaire @relation(fields: [questionnaireId], references: [id], onDelete: Cascade)
}

model Recommandation {
  id                 String     @id @default(uuid())
  scoreCompatibilite Float
  rang               Int
  userId             String
  specialiteId       String
  user               User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  specialite         Specialite @relation(fields: [specialiteId], references: [id], onDelete: Cascade)
}

model ParametresRecommandation {
  id             String @id @default(uuid())
  poidsScore     Float
  poidsInterets  Float
  poidsMatieres  Float
}

model JournalAudit {
  id         String   @id @default(uuid())
  action     String
  dateAction DateTime @default(now())
}
