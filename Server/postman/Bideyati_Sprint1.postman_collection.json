    {
      "name": "Register",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "if (!pm.environment.get('email') || pm.environment.get('email').includes('@test.com')) {",
              "  const randomEmail = `student_${Date.now()}@test.com`;",
              "  pm.environment.set('email', randomEmail);",
              "}",
              "if (!pm.environment.get('numeroBAC')) {",
              "  pm.environment.set('numeroBAC', `BAC-${Date.now()}`);",
              "}"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 201', function () {",
              "  pm.response.to.have.status(201);",
              "});",
              "const json = pm.response.json();",
              "pm.environment.set('token', json.token);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"nom\": \"Razil\",\n  \"prenom\": \"Student\",\n  \"email\": \"{{email}}\",\n  \"telephone\": \"0550000000\",\n  \"motDePasse\": \"StrongPass123\",\n  \"numeroBAC\": \"{{numeroBAC}}\",\n  \"moyenneBac\": 15.5\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/auth/register",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "auth",
            "register"
          ]
        }
      }
    },
